{
  "info": {
    "name": "my-akka-kata",
    "description": "Customer + Preferences API (Akka SDK Day 1 kata) — create/delete/list customers, update email, set/get preferences.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:9000"
    },
    {
      "key": "customerId",
      "value": "c1"
    },
    {
      "key": "fromCustomerId",
      "value": "c1"
    },
    {
      "key": "toCustomerId",
      "value": "c2"
    },
    {
      "key": "transferId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Customer",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"FirstName\": \"Ada\",\n  \"LastName\": \"Lovelace\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers"]
        }
      }
    },
    {
      "name": "Get All Customers",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers"]
        }
      }
    },
    {
      "name": "Update Customer Email",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ada@example.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}/email",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}", "email"]
        }
      }
    },
    {
      "name": "Set Preferences",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"theme\": \"dark\",\n  \"locale\": \"en-US\",\n  \"marketingOptIn\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}/preferences",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}", "preferences"]
        }
      }
    },
    {
      "name": "Get Preferences",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}/preferences",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}", "preferences"]
        }
      }
    },
    {
      "name": "Add Education",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"institution\": \"MIT\",\n  \"degree\": \"BSc\",\n  \"startYear\": 2010,\n  \"endYear\": 2014\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}/profile/education",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}", "profile", "education"]
        }
      }
    },
    {
      "name": "Add Work Experience",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company\": \"Acme\",\n  \"title\": \"Engineer\",\n  \"startYear\": 2014,\n  \"endYear\": 2018\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}/profile/work",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}", "profile", "work"]
        }
      }
    },
    {
      "name": "Get Customer Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}/profile",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}", "profile"]
        }
      }
    },
    {
      "name": "Delete Customer",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/customers/{{customerId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "customers", "{{customerId}}"]
        }
      }
    },
    {
      "name": "Customer Accounts",
      "item": [
        {
          "name": "Credit From-Customer Account",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountCents\": 10000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{fromCustomerId}}/account/credit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{fromCustomerId}}", "account", "credit"]
            }
          }
        },
        {
          "name": "Debit From-Customer Account",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountCents\": 1000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{fromCustomerId}}/account/debit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{fromCustomerId}}", "account", "debit"]
            }
          }
        },
        {
          "name": "Get From-Customer Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{fromCustomerId}}/account",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{fromCustomerId}}", "account"]
            }
          }
        },
        {
          "name": "Get To-Customer Balance",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{toCustomerId}}/account",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{toCustomerId}}", "account"]
            }
          }
        },
        {
          "name": "Freeze To-Customer Account",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{toCustomerId}}/account/freeze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{toCustomerId}}", "account", "freeze"]
            }
          }
        },
        {
          "name": "Unfreeze To-Customer Account",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/{{toCustomerId}}/account/unfreeze",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", "{{toCustomerId}}", "account", "unfreeze"]
            }
          }
        }
      ]
    },
    {
      "name": "Transfers (Workflow)",
      "item": [
        {
          "name": "Start Transfer - Pass (sufficient funds)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('transferId', json.transferId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromCustomerId\": \"{{fromCustomerId}}\",\n  \"toCustomerId\": \"{{toCustomerId}}\",\n  \"amountCents\": 3000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers"]
            }
          }
        },
        {
          "name": "Start Transfer - Fail (insufficient funds)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('transferId', json.transferId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fromCustomerId\": \"{{fromCustomerId}}\",\n  \"toCustomerId\": \"{{toCustomerId}}\",\n  \"amountCents\": 999999999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transfers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers"]
            }
          }
        },
        {
          "name": "Get Transfer Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/{{transferId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "{{transferId}}"]
            }
          }
        },
        {
          "name": "Get Transfer History (audit trail)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transfers/{{transferId}}/history",
              "host": ["{{baseUrl}}"],
              "path": ["api", "transfers", "{{transferId}}", "history"]
            }
          }
        }
      ]
    }
  ]
}
